#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

ENV_FILE="/config/aio/generated.env"
if [ -f "${ENV_FILE}" ]; then
    set -a
    . "${ENV_FILE}"
    set +a
fi

export HOME="/home/appuser"
export USER="appuser"
export LOGNAME="appuser"

exec /command/s6-setuidgid appuser python3 /usr/local/bin/aio-template-app.py
