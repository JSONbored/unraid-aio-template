<?xml version="1.0"?>
<Container version="2">
  <Name>yourapp-aio</Name>
  <Repository>ghcr.io/jsonbored/yourapp-aio:latest</Repository>
  <Registry>https://ghcr.io/jsonbored/yourapp-aio</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/JSONbored/yourapp-aio/issues</Support>
  <Project>https://github.com/JSONbored/yourapp-aio</Project>
  <Overview>Replace this overview with the real app description and first-run guidance.</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/JSONbored/awesome-unraid/main/yourapp-aio.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/JSONbored/awesome-unraid/main/icons/yourapp.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description/>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8080</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yourapp-aio/config</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yourapp-aio/data</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment/>

  <Config Name="Web UI Port" Target="8080" Default="8080" Mode="tcp" Description="Replace with the main app port." Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="AppData - Config" Target="/config" Default="/mnt/user/appdata/yourapp-aio/config" Mode="rw" Description="Persistent app configuration." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/yourapp-aio/config</Config>
  <Config Name="AppData - Data" Target="/data" Default="/mnt/user/appdata/yourapp-aio/data" Mode="rw" Description="Persistent app data." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/yourapp-aio/data</Config>
  <Config Name="Example Variable" Target="APP_EXAMPLE" Default="" Mode="" Description="Replace with a real variable or remove it." Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>
